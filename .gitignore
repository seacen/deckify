# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# OS
.DS_Store
Thumbs.db

# Eval run output (regenerated each run)
skills/*/tests/reports/runs/
skills/*/tests/reports/visual-check/
# Repo-root tests/ tree mirrors the same shape — runs/<ts>/ is per-run output;
# don't commit screenshots / measurements / per-sample reports.
tests/reports/runs/
tests/reports/visual-check/

# Sample workspace artifacts that are large + regenerable
# (keep brand.json + pages.txt + assets/ — they're the LLM/quality-gate output)
samples/*/recon/
samples/*/raw-assets.json
samples/*/eval-output/

# Phase 1 transient workspace — should live in OS tempdir (init_workspace.py)
# but gitignore the in-project locations too as defense in depth
.web-to-ds-workspace/
.deckify-workspace/

# Local backups (user-managed, not part of the skill)
decks/backup/

# Editor scratch
.idea/
.vscode/
*.swp
*~

# Claude Code session state
.claude/
